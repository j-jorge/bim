msgid "Please wait"
msgstr "Por favor, espera"

msgid "You have been disconnected :("
msgstr "Has sido desconectado :("

msgid ""
"The shop is not available on this platform, yet you can support the "
"developers with donations! Should I open the donations page?"
msgstr ""
"La tienda no está disponible en esta plataforma, ¡pero puedes apoyar a los "
"desarrolladores con donaciones! ¿Te abro la página de donaciones?"

msgid "Do you really want to change the language setting?"
msgstr "¿Realmente deseas cambiar la configuración de idioma?"

#, c++-format
msgid "Version {}"
msgstr "Versión {}"

msgid "Feedback about Bim!"
msgstr "Haz un comentario sobre Bim!"

msgid ""
"Come play a game of Bim! https://play.google.com/store/apps/details?"
"id=bim.app"
msgstr ""
"Juguemos una partida de Bim! https://play.google.com/store/apps/details?"
"id=bim.app"

msgid "You need more coins to purchase this item!"
msgstr "¡Necesitas más monedas para poder comprar este artículo!"

#, c++-format
msgid "Customize your games with up to {} feature."
msgid_plural "Customize your games with up to {} features."
msgstr[0] "Personalizá tus juegos con hasta {} característica."
msgstr[1] "Personalizá tus juegos con hasta {} características."

msgid "Falling blocks reduce the arena after two minutes!"
msgstr "¡Los bloques que caen reducen la arena después de dos minutos!"

msgid "Fences block the players, but the flames can go through!"
msgstr ""
"Las vallas bloquean el paso a los jugadores, ¡pero las llamas pueden "
"atravesarlas!"

msgid "A thick fog covers the arena. You can't see were you did not go!"
msgstr "Una espesa niebla cubre la arena. ¡No puedes ver donde no has ido!"

msgid ""
"Find the invisibility power up to disappear from the screen of all other "
"players!"
msgstr ""
"¡Encuentra el potenciador de invisibilidad para desaparecer de la pantalla "
"de todos los demás jugadores!"

msgid "Find this incredibly strong barrel, it will save you from one hit!"
msgstr ""
"¡Encuentra este barril increíblemente resistente, te salvará de un golpe!"

#, c++-format
msgid "{} game being played right now."
msgid_plural "{} games being played right now."
msgstr[0] "{} juego que se está jugando ahora mismo."
msgstr[1] "{} juegos que se está jugando ahora mismo."

#, c++-format
msgid "{} player connected right now."
msgid_plural "{} players connected right now."
