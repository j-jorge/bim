msgstr "Cancelar"

msgid "OK"
msgstr "Aceptar"

msgid ""
"NEW\n"
"GAME"
msgstr ""
"JUEGO\n"
"NUEVO"

msgid ""
"Start a new game\n"
"and get your revenge!"
msgstr ""
"Inicia un juego nuevo y\n"
"¡logra tu revancha!"

msgid ""
"Was it pure luck?\n"
"Confirm your skills in a new game!"
msgstr ""
"¿Fue pura suerte?\n"
"¡Pon a prueba tus habilidades en una partida nueva!"

msgid "Draw game!"
msgstr "¡Juego de dibujo!"

msgid "You lost!"
msgstr "¡Has perdido!"

